PORT=8080
CORS_ORIGIN=http://localhost:5173
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
RATE_LIMIT_WRITE_MAX=60
DATABASE_URL=postgres://dev:dev@localhost/workout-tracker
# TLS: omit or false for local Postgres / CI. true (or sslmode=require in URL) for managed hosts.
# DB_SSL=false
# DB_SSL_REJECT_UNAUTHORIZED=true
# PG_POOL_MAX=10
TOKEN_SECRET=changeMe

# Demo JWT sign-up / sign-in / guest. Set false in production when OIDC is primary.
# AUTH_DEMO_ENABLED=true

# --- OIDC (optional). When AUTH_OIDC_ENABLED=true, issuer, client id, and redirect URI are required.
# AUTH_OIDC_ENABLED=false
# AUTH_OIDC_ISSUER=https://YOUR_TENANT.auth0.com/
# AUTH_OIDC_CLIENT_ID=
# Optional for confidential clients (Auth0 “Regular Web Application”).
# AUTH_OIDC_CLIENT_SECRET=
# Must match an Allowed Callback URL in the IdP. With Vite dev proxy, use the browser origin:
# AUTH_OIDC_REDIRECT_URI=http://localhost:5173/api/auth/oidc/callback
# Relative path after successful login (same origin as redirect URI in dev).
# AUTH_POST_LOGIN_PATH=/
# Min 16 chars when OIDC is on (else TOKEN_SECRET >= 16 chars is used for cookie signing).
# SESSION_SECRET=
# AUTH_OIDC_LOGIN_STATE_TTL_SECONDS=600
# SESSION_TTL_SECONDS=604800
# lax | strict | none (none needs Secure; use only with HTTPS and explicit need).
# SESSION_COOKIE_SAME_SITE=lax
