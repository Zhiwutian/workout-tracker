{
  "extends": "./node_modules/@learningfuze/lfz-config/config/eslintrc.json",
  "overrides": [
    {
      "files": ["server/**/*.ts"],
      "rules": {
        "@typescript-eslint/no-unused-vars": [
          "error",
          {
            "argsIgnorePattern": "^_",
            "varsIgnorePattern": "^_"
          }
        ]
      }
    }
  ]
}
